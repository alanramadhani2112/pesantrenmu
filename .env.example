APP_NAME=PesantrenMu
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

# Set ke CIDR load balancer production, e.g. "10.0.0.0/8"
# Kosongkan jika tidak ada reverse proxy (audit fix M-4)
TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=daily
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=spm_fix
DB_USERNAME=root
# WARNING: Jangan deploy ke production dengan password kosong.
# Gunakan password kuat (min 16 karakter random) dan simpan di vault/secret manager.
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
# Production: ganti ke "s3" (atau "r2"/"do" jika pakai kompatibel S3).
# Upload dokumen (PDF IPM, SDM, EDPM, sertifikat, kartu kendali, dll)
# HARUS persistent — "local"/"public" disk akan hilang saat deployment ulang.
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Production: gunakan smtp, SES, atau Mailgun. Jangan pakai `log` — email tidak akan terkirim.
MAIL_MAILER=smtp
# MAIL_SCHEME=tls
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false

AKREDITASI_POLLING_INTERVAL=10
AKREDITASI_PRESENCE_ENABLED=false
TRASH_RETENTION_DAYS=90

SSO_ENABLED=false
SSO_SERVER_URL=http://localhost:8000
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=
SSO_SCOPES="openid profile email"
